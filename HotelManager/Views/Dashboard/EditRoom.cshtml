@model Room
@{
    ViewData["Title"] = "Edit Room";
    Layout = "_Layout";
}

<style>
    .footer {
        visibility: hidden;
    }

    .input-group-text {
        background-color: #1a3c40;
        color: white;
        border: none;
    }
</style>

<div class="container mt-4">
    <h1 class="mb-4">Edit Room</h1>

    <!-- Display Success/Error Messages -->
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-circle me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header bg-warning text-white">
                    <h4 class="mb-0"><i class="fas fa-edit me-2"></i>Edit Room Details</h4>
                </div>
                <div class="card-body">
                    <form asp-action="EditRoom" method="post" id="editRoomForm">
                        <div asp-validation-summary="All" class="text-danger"></div>
                        <input type="hidden" asp-for="RoomId" />

                        <div class="form-group mb-3">
                            <label asp-for="HotelId" class="control-label fw-bold">Hotel</label>
                            <select asp-for="HotelId" class="form-control" asp-items="@(new SelectList(ViewBag.Hotels, "HotelId", "Name"))" required>
                                <option value="">-- Select Hotel --</option>
                            </select>
                            <span asp-validation-for="HotelId" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="RoomDescription" class="control-label fw-bold">Room Type</label>
                            <select asp-for="RoomDescription" class="form-control" required>
                                <option value="">-- Select Room Type --</option>
                                <option value="Deluxe">Deluxe</option>
                                <option value="Premium">Premium</option>
                                <option value="Presidential">Presidential</option>
                            </select>
                            <span asp-validation-for="RoomDescription" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="PricePerNight" class="control-label fw-bold">Price Per Night (R)</label>
                            <div class="input-group">
                                <span class="input-group-text">R</span>
                                <input asp-for="PricePerNight" class="form-control" type="number" step="0.01" min="1" required />
                            </div>
                            <span asp-validation-for="PricePerNight" class="text-danger"></span>
                            <small class="text-muted">Enter price in Rand (e.g., 1500.00)</small>
                        </div>

                        <div class="form-group mt-4">
                            <button type="submit" class="btn btn-warning">
                                <i class="fas fa-save me-2"></i>Update Room
                            </button>
                            <a asp-action="Rooms" class="btn btn-secondary">
                                <i class="fas fa-times me-2"></i>Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card shadow-sm bg-light">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0"><i class="fas fa-info-circle me-2"></i>Edit Information</h5>
                </div>
                <div class="card-body">
                    <p>You are editing room with ID: <strong>@Model.RoomId</strong></p>

                    <h6>Room Types:</h6>
                    <ul class="list-unstyled">
                        <li><span class="badge bg-secondary me-2">Deluxe</span> - Standard room with essential amenities</li>
                        <li class="mt-2"><span class="badge bg-secondary me-2">Premium</span> - Enhanced room with extra features</li>
                        <li class="mt-2"><span class="badge bg-secondary me-2">Presidential</span> - Luxury suite with premium services</li>
                    </ul>

                    <div class="alert alert-warning mt-3">
                        <i class="fas fa-exclamation-triangle me-2"></i>
                        <strong>Note:</strong> Changes will affect future bookings only.
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        $(document).ready(function() {
            // Format price to 2 decimal places on blur
            $('#PricePerNight').on('blur', function() {
                var value = $(this).val();
                if (value && !isNaN(value)) {
                    $(this).val(parseFloat(value).toFixed(2));
                }
            });

            // Log form submission for debugging
            $('#editRoomForm').on('submit', function() {
                console.log('Edit form submitted');
                console.log('RoomId: ' + $('#RoomId').val());
                console.log('HotelId: ' + $('#HotelId').val());
                console.log('RoomDescription: ' + $('#RoomDescription').val());
                console.log('PricePerNight: ' + $('#PricePerNight').val());
            });
        });
    </script>
}