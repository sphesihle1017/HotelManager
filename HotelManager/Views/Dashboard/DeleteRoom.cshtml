@model Room
@{
    ViewData["Title"] = "Delete Room";
    Layout = "_Layout";
}

<style>
    .footer {
        visibility: hidden;
    }

    .delete-icon {
        font-size: 5rem;
        color: #dc3545;
        margin-bottom: 1rem;
    }

    .room-details {
        background-color: #f8f9fa;
        border-left: 4px solid #dc3545;
        padding: 1.5rem;
        border-radius: 0.5rem;
        margin: 1.5rem 0;
    }

    .detail-item {
        padding: 0.5rem 0;
        border-bottom: 1px solid #dee2e6;
    }

        .detail-item:last-child {
            border-bottom: none;
        }

    .detail-label {
        font-weight: 600;
        color: #495057;
        width: 120px;
        display: inline-block;
    }

    .warning-box {
        background-color: #fff3cd;
        border: 1px solid #ffeeba;
        color: #856404;
        padding: 1rem;
        border-radius: 0.5rem;
        margin: 1.5rem 0;
    }
</style>

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm border-danger">
                <div class="card-header bg-danger text-white text-center">
                    <h4 class="mb-0"><i class="fas fa-exclamation-triangle me-2"></i>Delete Room Confirmation</h4>
                </div>

                <div class="card-body text-center">
                    <div class="delete-icon">
                        <i class="fas fa-trash-alt"></i>
                    </div>

                    <h3 class="mb-3">Are you sure?</h3>
                    <p class="text-muted mb-4">You are about to delete the following room. This action cannot be undone.</p>

                    <div class="room-details text-start">
                        <h5 class="text-danger mb-3"><i class="fas fa-door-open me-2"></i>Room Information</h5>

                        <div class="detail-item">
                            <span class="detail-label">Room ID:</span>
                            <span class="fw-bold">#@Model.RoomId</span>
                        </div>

                        <div class="detail-item">
                            <span class="detail-label">Hotel:</span>
                            <span class="fw-bold">@(Model.Hotel?.Name ?? "N/A")</span>
                        </div>

                        <div class="detail-item">
                            <span class="detail-label">Room Type:</span>
                            <span class="badge bg-primary">@Model.RoomDescription</span>
                        </div>

                        <div class="detail-item">
                            <span class="detail-label">Price/Night:</span>
                            <span class="fw-bold text-success">R @Model.PricePerNight.ToString("N2")</span>
                        </div>

                        @if (Model.Bookings != null && Model.Bookings.Any())
                        {
                            <div class="detail-item">
                                <span class="detail-label">Bookings:</span>
                                <span class="badge bg-info">@Model.Bookings.Count active bookings</span>
                            </div>
                        }
                    </div>

                    @if (Model.Bookings != null && Model.Bookings.Any())
                    {
                        <div class="warning-box">
                            <i class="fas fa-exclamation-circle me-2"></i>
                            <strong>Warning:</strong> This room has existing bookings and cannot be deleted.
                            <div class="mt-2">
                                <small>Please cancel or complete all bookings first.</small>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="warning-box">
                            <i class="fas fa-info-circle me-2"></i>
                            <strong>Note:</strong> This room has no active bookings and can be safely deleted.
                        </div>
                    }

                    <form asp-action="DeleteRoom" method="post" class="mt-4">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.RoomId" />

                        <div class="d-flex justify-content-center gap-3">
                            @if (Model.Bookings == null || !Model.Bookings.Any())
                            {
                                <button type="submit" class="btn btn-danger px-4" onclick="return confirmDelete();">
                                    <i class="fas fa-trash me-2"></i>Yes, Delete Room
                                </button>
                            }
                            else
                            {
                                <button type="button" class="btn btn-secondary px-4" disabled>
                                    <i class="fas fa-ban me-2"></i>Cannot Delete
                                </button>
                            }

                            <a asp-action="Rooms" class="btn btn-outline-secondary px-4">
                                <i class="fas fa-times me-2"></i>Cancel
                            </a>
                        </div>
                    </form>
                </div>

                <div class="card-footer bg-light text-muted text-center small">
                    <i class="fas fa-shield-alt me-1"></i>
                    This action will permanently delete this room from the database.
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function confirmDelete() {
            return confirm('Are you absolutely sure you want to delete this room? This action cannot be reversed.');
        }
    </script>
}